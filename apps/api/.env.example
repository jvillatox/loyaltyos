# Database
DATABASE_URL=postgresql://loyaltyos:loyaltyos_dev@localhost:5432/loyaltyos_dev

# Redis
REDIS_URL=redis://localhost:6379

# Server
PORT_API=3002
HOST=0.0.0.0
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173
LOG_LEVEL=info

# Auth
JWT_SECRET=change-me-in-production
API_KEY_SALT=change-me-in-production

# Coalition (Puntos Apprecio)
APPRECIO_API_ENDPOINT=https://api.puntos.apprecio.com/v1
APPRECIO_API_KEY=your-apprecio-api-key
APPRECIO_MERCHANT_ID=your-merchant-id

# Notifications (Resend)
RESEND_API_KEY=re_your_resend_key

# Notifications (Twilio)
TWILIO_ACCOUNT_SID=AC_your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=+1234567890
# Override for testing — leave unset for production
TWILIO_API_BASE=
# Notifications (OneSignal)
ONESIGNAL_APP_ID=your_onesignal_app_id
ONESIGNAL_API_KEY=your_onesignal_api_key
# Override for testing — leave unset for production
ONESIGNAL_API_BASE=
