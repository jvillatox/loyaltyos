# Database
DATABASE_URL=postgresql://loyaltyos:loyaltyos_dev@localhost:5432/loyaltyos_dev

# Redis
REDIS_URL=redis://localhost:6379

# Server
PORT_API=3002
HOST=0.0.0.0
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173
LOG_LEVEL=info

# Auth
JWT_SECRET=change-me-in-production
API_KEY_SALT=change-me-in-production

# Coalition — Apprecio (real API)
# Country URLs: MX https://apiv2.dcanje.mx/api · CL https://api.apprecio.cl/api
#               CO https://apiv2.apprecio.com.co/api · PE https://apiv2.apprecio.pe/api
#               EC https://apiv2.ec.dcanje.com/api
APPRECIO_API_BASE=https://apiv2.dcanje.mx/api
APPRECIO_PUBLIC_TOKEN=
APPRECIO_PRIVATE_TOKEN=
APPRECIO_IDENTIFIER_TYPE=email
APPRECIO_TIMEOUT_MS=10000

# Notifications (Resend)
RESEND_API_KEY=re_your_resend_key

# Notifications (Twilio)
TWILIO_ACCOUNT_SID=AC_your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=+1234567890
# Override for testing — leave unset for production
TWILIO_API_BASE=
# Notifications (OneSignal)
ONESIGNAL_APP_ID=your_onesignal_app_id
ONESIGNAL_API_KEY=your_onesignal_api_key
# Override for testing — leave unset for production
ONESIGNAL_API_BASE=
