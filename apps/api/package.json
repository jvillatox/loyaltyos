{
  "name": "@loyaltyos/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:reset": "prisma migrate reset --force",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/swagger": "^8.14.0",
    "@fastify/swagger-ui": "^3.0.0",
    "@loyaltyos/badges": "workspace:*",
    "@loyaltyos/campaigns": "workspace:*",
    "@loyaltyos/coalition": "workspace:*",
    "@loyaltyos/core": "workspace:*",
    "@loyaltyos/coupons": "workspace:*",
    "@loyaltyos/notifications": "workspace:*",
    "@loyaltyos/rewards": "workspace:*",
    "@loyaltyos/segments": "workspace:*",
    "@loyaltyos/telemetry": "workspace:*",
    "@lucia-auth/adapter-prisma": "^4.0.1",
    "@prisma/client": "^5.15.0",
    "argon2": "^0.44.0",
    "bullmq": "^5.76.9",
    "fastify": "^4.28.0",
    "fastify-plugin": "^5.1.0",
    "ioredis": "^5.10.1",
    "lucia": "^3.2.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@loyaltyos/config-eslint": "workspace:*",
    "@loyaltyos/config-prettier": "workspace:*",
    "@types/supertest": "^6.0.2",
    "prisma": "^5.15.0",
    "supertest": "^7.0.0",
    "tsx": "^4.15.6",
    "typescript": "^5.5.2",
    "vitest": "^1.6.0"
  }
}
