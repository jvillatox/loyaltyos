{
  "name": "@loyaltyos/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:reset": "prisma migrate reset --force",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@loyaltyos/core": "workspace:*",
    "@prisma/client": "^5.15.0",
    "fastify": "^4.28.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/swagger": "^8.14.0",
    "@fastify/swagger-ui": "^3.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@loyaltyos/config-eslint": "workspace:*",
    "@loyaltyos/config-prettier": "workspace:*",
    "prisma": "^5.15.0",
    "typescript": "^5.5.2",
    "tsx": "^4.15.6",
    "vitest": "^1.6.0",
    "supertest": "^7.0.0",
    "@types/supertest": "^6.0.2"
  }
}
