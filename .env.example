# ─── Database ───
DATABASE_URL=postgresql://loyaltyos:loyaltyos_dev@localhost:5432/loyaltyos_dev

# ─── Redis ───
REDIS_URL=redis://localhost:6379

# ─── Security ───
JWT_SECRET=change-me-to-a-random-64-char-string
API_KEY_SALT=change-me-to-a-random-32-char-string

# ─── API Server ───
NODE_ENV=development
PORT_API=3000
PORT_ADMIN=5173

# ─── Coalition - Puntos Apprecio ───
APPRECIO_API_ENDPOINT=https://api.puntos.apprecio.com/v1
APPRECIO_API_KEY=your-apprecio-api-key
APPRECIO_MERCHANT_ID=your-apprecio-merchant-id

# ─── Notifications ───
# Email (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxx
# SMS (Twilio)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token

# ─── Optional ───
# SENTRY_DSN=
# LOG_LEVEL=debug
