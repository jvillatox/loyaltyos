        {
          "datasource": { "type": "prometheus" },
          "expr": "sum(rate(http_requests_total{service_name=\"$service\",status_code=~\"4..\"}[$__rate_interval])) / sum(rate(http_requests_total{service_name=\"$service\"}[$__rate_interval]))",
          "legendFormat": "4xx Error Rate"
        }
