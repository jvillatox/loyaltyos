      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "sum(rate(http_requests_total{service_name=\"$service\",status_code=~\"5..\"}[$__rate_interval])) / sum(rate(http_requests_total{service_name=\"$service\"}[$__rate_interval]))",
          "legendFormat": "5xx Error Rate"
