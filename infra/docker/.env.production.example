# LoyaltyOS — Production Environment Variables
# Copy this file to .env.production and fill in your values:
#   cp infra/docker/.env.production.example infra/docker/.env.production
#
# Then start the production stack:
#   docker compose -f infra/docker/docker-compose.prod.yml --env-file infra/docker/.env.production up -d

# ── Database ─────────────────────────────────────────────
POSTGRES_USER=loyaltyos
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=loyaltyos

# ── Server ───────────────────────────────────────────────
PORT_API=3002
PORT_ADMIN=5173
PORT_PORTAL=5174
NODE_ENV=production
CORS_ORIGIN=https://your-domain.com
LOG_LEVEL=info

# ── Auth ─────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-use-64-char-random
API_KEY_SALT=change-me-in-production-use-32-char-random

# ── Credential Encryption ────────────────────────────────
# 32-byte hex string for AES-256-GCM. Generate with: openssl rand -hex 32
KMS_MASTER_KEY=change-me-in-production

# ── Email (Resend) ───────────────────────────────────────
RESEND_API_KEY=re_your_resend_key

# ── SMS (Twilio) ─────────────────────────────────────────
TWILIO_ACCOUNT_SID=AC_your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=+1234567890
# TWILIO_API_BASE=   # Override for testing — leave empty for production

# ── Push (OneSignal) ─────────────────────────────────────
ONESIGNAL_APP_ID=your_onesignal_app_id
ONESIGNAL_API_KEY=your_onesignal_api_key
# ONESIGNAL_API_BASE= # Override for testing — leave empty for production

# ── Coalition — Apprecio ─────────────────────────────────
# Country URLs:
#   MX: https://apiv2.dcanje.mx/api
#   CL: https://api.apprecio.cl/api
#   CO: https://apiv2.apprecio.com.co/api
#   PE: https://apiv2.apprecio.pe/api
#   EC: https://apiv2.ec.dcanje.com/api
APPRECIO_API_BASE=https://apiv2.dcanje.mx/api
APPRECIO_PUBLIC_TOKEN=your_apprecio_public_token
APPRECIO_PRIVATE_TOKEN=your_apprecio_private_token
APPRECIO_IDENTIFIER_TYPE=email
APPRECIO_TIMEOUT_MS=10000

# ── Observability ──────────────────────────────────────────
# OpenTelemetry — set the OTLP endpoint to enable distributed tracing
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318/v1/traces
# OTEL_SERVICE_NAME=loyaltyos-api
# WORKER_METRICS_PORT=3003   # Port for the standalone worker metrics/health server
